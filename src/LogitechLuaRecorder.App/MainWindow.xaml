<Window x:Class="LogitechLuaRecorder.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Height="780"
        Width="1400"
        MinHeight="640"
        MinWidth="1120">
    <DockPanel Margin="12">
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New" Click="New_Click" />
                <MenuItem Header="_Open..." Click="Open_Click" />
                <Separator />
                <MenuItem Header="_Save" Click="Save_Click" />
                <MenuItem Header="Save _As..." Click="SaveAs_Click" />
                <Separator />
                <MenuItem Header="E_xit" Click="Exit_Click" />
            </MenuItem>
            <MenuItem Header="_Recording">
                <MenuItem Header="_Toggle Recording" Click="ToggleRecording_Click" />
                <Separator />
                <MenuItem Header="_Delete Selected Event" Click="DeleteSelectedEvent_Click" />
            </MenuItem>
            <MenuItem Header="_Options">
                <MenuItem Header="_Settings..." Click="Settings_Click" />
            </MenuItem>
        </Menu>

        <Border DockPanel.Dock="Top"
                Margin="0,8,0,12"
                Padding="12"
                CornerRadius="10"
                Background="#FFF5F7FB"
                BorderBrush="#FFD7DFEA"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Button Padding="14,6" Margin="0,0,8,0" Click="New_Click">New</Button>
                    <Button Padding="14,6" Margin="0,0,8,0" Click="Open_Click">Open</Button>
                    <Button Padding="14,6" Margin="0,0,8,0" Click="Save_Click">Save</Button>
                    <Button Padding="14,6" Margin="0,0,8,0" Click="SaveAs_Click">Save As</Button>
                    <Button Padding="14,6"
                            Margin="12,0,8,0"
                            Background="{Binding RecordingToggleButtonBackground}"
                            Foreground="White"
                            Click="ToggleRecording_Click"
                            Content="{Binding RecordingToggleButtonText}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Center">
                    <TextBlock VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold">Macro Name</TextBlock>
                    <TextBox Width="220" Text="{Binding MacroName, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Center">
                    <TextBlock VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold">Trigger G-Key</TextBlock>
                    <TextBox Width="60" Text="{Binding TriggerGKey, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Padding="10,6" Margin="0,0,8,0" Click="MoveUp_Click">Move Up</Button>
                    <Button Padding="10,6" Margin="0,0,8,0" Click="MoveDown_Click">Move Down</Button>
                    <Button Padding="10,6" Click="DeleteSelectedEvent_Click">Delete Selected</Button>
                </StackPanel>
            </Grid>
        </Border>

        <DataGrid x:Name="EventsDataGrid"
                  ItemsSource="{Binding Events}"
                  SelectedItem="{Binding SelectedEvent, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Extended"
                  SelectionUnit="FullRow"
                  SelectionChanged="EventsDataGrid_SelectionChanged"
                  CellEditEnding="EventsDataGrid_CellEditEnding"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  Margin="0,0,0,12"
                  RowHeaderWidth="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="#" Binding="{Binding SequenceNumber}" IsReadOnly="True" Width="50" />
                <DataGridTextColumn Header="Delay (ms)" Binding="{Binding DelayBeforeMs, UpdateSourceTrigger=PropertyChanged}" Width="96" />
                <DataGridTextColumn Header="Kind" Binding="{Binding KindName, UpdateSourceTrigger=PropertyChanged}" Width="110" />
                <DataGridTextColumn Header="Action" Binding="{Binding ActionName, UpdateSourceTrigger=PropertyChanged}" Width="100" />
                <DataGridTextColumn Header="Key" Binding="{Binding KeyIdentifier, UpdateSourceTrigger=PropertyChanged}" Width="140" />
                <DataGridTextColumn Header="Mouse Button" Binding="{Binding MouseButtonName, UpdateSourceTrigger=PropertyChanged}" Width="130" />
                <DataGridTextColumn Header="X" Binding="{Binding X, UpdateSourceTrigger=PropertyChanged}" Width="90" />
                <DataGridTextColumn Header="Y" Binding="{Binding Y, UpdateSourceTrigger=PropertyChanged}" Width="90" />
                <DataGridTextColumn Header="Wheel Delta" Binding="{Binding WheelDelta, UpdateSourceTrigger=PropertyChanged}" Width="110" />
                <DataGridTextColumn Header="Summary" Binding="{Binding Summary}" IsReadOnly="True" Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <Border DockPanel.Dock="Bottom"
                Padding="12"
                CornerRadius="10"
                Background="#FF111827">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Text="{Binding StatusText}" Foreground="White" FontSize="14" />
                <TextBlock Grid.Row="1"
                           Margin="0,6,0,0"
                           Text="{Binding HotkeySummary}"
                           Foreground="#FFFDE68A"
                           FontSize="12" />
                <TextBlock Grid.Row="1"
                           Margin="160,6,0,0"
                           Text="{Binding SelectionSummary}"
                           Foreground="#FFFCA5A5"
                           FontSize="12" />
                <TextBlock Grid.Row="1"
                           Margin="320,6,0,0"
                           Text="{Binding CaptureBoundsSummary}"
                           Foreground="#FFBFDBFE"
                           FontSize="12" />
            </Grid>
        </Border>
    </DockPanel>
</Window>
